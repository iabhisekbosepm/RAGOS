# ── CC-RAGOS environment ─────────────────────────────────────────────
# Copy to .env and fill. NEVER commit .env.

# OpenRouter (LLM + vision + embeddings).
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Text embeddings. Images are captioned by a vision LLM then embedded here (best retrieval).
# Direct multimodal embedders exist (google/gemini-embedding-2) but retrieved worse in testing.
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_DIM=3072
LLM_MODEL=anthropic/claude-opus-4.8
VISION_MODEL=google/gemini-3-flash-preview

# Qdrant (vectors: dense + sparse BM25 + ColPali multi-vector). Host-native: localhost.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ccragos_chunks

# Neo4j (knowledge graph — Phase 4, unused for now)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_strong

# Retriever / ingestion service ports
RETRIEVER_PORT=8100
INGESTION_PORT=8101

NEXT_PUBLIC_RETRIEVER_URL=http://localhost:8100
INGESTION_URL=http://localhost:8101

# Deepgram Aura TTS (Audio Overview) — free $200 credit at deepgram.com
DEEPGRAM_API_KEY=

# Out-of-scope gate: min dense cosine to allow an answer (raise to be stricter)
RELEVANCE_THRESHOLD=0.22

# ── Auth (self-contained JWT + RBAC; no external IdP) ──
# OFF by default: app runs open. Set AUTH_ENABLED=true to enforce login + roles.
AUTH_ENABLED=false
AUTH_SECRET=change-me-to-a-long-random-string     # HS256 signing key — REQUIRED when enabled
AUTH_TOKEN_TTL_HOURS=12
AUTH_ADMIN_USER=admin                             # first admin, seeded once on startup
AUTH_ADMIN_PASSWORD=change_me_strong              # CHANGE THIS before enabling auth
NEXT_PUBLIC_INGESTION_URL=http://localhost:8101

# Langfuse observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
